#!/usr/bin/env bash
set -euo pipefail

# --- version ---
VERSION="0.1.0"

# --- defaults ---
FUZZ=10
BG_COLOR="auto"
COLOR_MODE="24bit"
WIDTH="auto"
HEIGHT=""
PROP=true
OUTPUT=""
PREVIEW=false
RENDERER="ascii"
INPUT=""

# --- helpers ---
die() { echo "img2term: error: $*" >&2; exit 1; }

check_deps() {
    command -v magick >/dev/null 2>&1 || die "imagemagick not found (pacman -S imagemagick)"
    if [[ "$RENDERER" == "ascii" ]]; then
        command -v jp2a >/dev/null 2>&1 || die "jp2a not found (pacman -S jp2a)"
    else
        command -v chafa >/dev/null 2>&1 || die "chafa not found (pacman -S chafa)"
    fi
}

usage() {
    cat <<EOF
Usage: img2term <image> [options]

Options:
  --output=FILE         save ASCII art to file
  --preview=true        print ASCII art in terminal (default: false)
  --width=N|auto        width in columns (auto = terminal width, default: auto)
  --height=N|auto       height in lines (auto = terminal height)
  --color-mode=MODE     24bit | 8bit | bw  (default: 24bit)
  --bg-color=COLOR      auto | #rrggbb | white | black  (default: auto)
  --fuzz=N              background removal tolerance in %  (default: 5)
  --prop=true|false     keep aspect ratio when only width or height is set (default: true)
  --renderer=MODE       ascii (jp2a) | pixel (chafa)  (default: ascii)
  --version             show version
  -h, --help            show this help
EOF
}

# --- argument parsing ---
for arg in "$@"; do
    case "$arg" in
        --output=*)    OUTPUT="${arg#*=}" ;;
        --width=*)     WIDTH="${arg#*=}" ;;
        --height=*)    HEIGHT="${arg#*=}" ;;
        --color-mode=*)COLOR_MODE="${arg#*=}" ;;
        --bg-color=*)  BG_COLOR="${arg#*=}" ;;
        --fuzz=*)      FUZZ="${arg#*=}" ;;
        --preview=*)   PREVIEW="${arg#*=}" ;;
        --prop=*)      PROP="${arg#*=}" ;;
        --renderer=*)  RENDERER="${arg#*=}" ;;
        -h|--help)     usage; exit 0 ;;
        --version)     echo "img2term $VERSION"; exit 0 ;;
        -*)            die "unknown option: $arg" ;;
        *)             INPUT="$arg" ;;
    esac
done

# --- validation ---
check_deps
[[ -z "$INPUT" ]]      && die "no input file specified. Use: img2term <image> [options]"
[[ ! -f "$INPUT" ]]    && die "file not found: $INPUT"

case "$COLOR_MODE" in
    24bit|8bit|bw) ;;
    *) die "invalid --color-mode: $COLOR_MODE (use 24bit, 8bit or bw)" ;;
esac

case "$PREVIEW" in
    true|false) ;;
    *) die "invalid --preview: $PREVIEW (use true or false)" ;;
esac

case "$PROP" in
    true|false) ;;
    *) die "invalid --prop: $PROP (use true or false)" ;;
esac

case "$RENDERER" in
    ascii|pixel) ;;
    *) die "invalid --renderer: $RENDERER (use ascii or pixel)" ;;
esac

[[ -z "$OUTPUT" && "$PREVIEW" != "true" ]] && die "nothing to do: use --output=FILE and/or --preview=true"

# --- resolve auto dimensions ---
TERM_COLS="${COLUMNS:-$(tput cols 2>/dev/null || echo 60)}"
TERM_LINES="${LINES:-$(tput lines 2>/dev/null || echo 24)}"
[[ "$WIDTH"  == "auto" ]] && WIDTH="$TERM_COLS"
[[ "$HEIGHT" == "auto" ]] && HEIGHT="$TERM_LINES"

# --- background color detection ---
if [[ "$BG_COLOR" == "auto" ]]; then
    BG_COLOR=$(magick identify -format "%[pixel:u.p{0,0}]" "$INPUT" 2>/dev/null) \
        || die "could not read pixel color from $INPUT"
fi

# --- tmp file ---
TMP=$(mktemp /tmp/i2a_XXXXXX.png)
trap 'rm -f "$TMP"' EXIT

# --- step 1: remove background with magick ---
magick "$INPUT" \
    -fuzz "${FUZZ}%" \
    -transparent "$BG_COLOR" \
    -trim +repage \
    -bordercolor transparent -border 2x1 \
    "$TMP" \
    || die "magick failed to process $INPUT"

# --- step 2: calcul des proportions ---
if [[ "$PROP" == "true" && -n "$WIDTH" && -z "$HEIGHT" ]]; then
    IMG_W=$(magick identify -format "%w" "$TMP")
    IMG_H=$(magick identify -format "%h" "$TMP")
    HEIGHT=$(( (WIDTH * IMG_H) / (IMG_W * 2) ))
    [[ "$HEIGHT" -lt 1 ]] && HEIGHT=1
elif [[ "$PROP" == "true" && -n "$HEIGHT" && -z "$WIDTH" ]]; then
    IMG_W=$(magick identify -format "%w" "$TMP")
    IMG_H=$(magick identify -format "%h" "$TMP")
    WIDTH=$(( (HEIGHT * IMG_W * 2) / IMG_H ))
    [[ "$WIDTH" -lt 1 ]] && WIDTH=1
fi

# --- step 3: build renderer args ---
if [[ "$RENDERER" == "ascii" ]]; then
    JP2A_ARGS=()
    case "$COLOR_MODE" in
        24bit|8bit) JP2A_ARGS+=(--colors) ;;
        bw) ;;
    esac
    [[ -n "$WIDTH" ]]  && JP2A_ARGS+=(--width="$WIDTH")
    [[ -n "$HEIGHT" ]] && JP2A_ARGS+=(--height="$HEIGHT")
else
    CHAFA_ARGS=(--format=symbols)
    case "$COLOR_MODE" in
        24bit) CHAFA_ARGS+=(--colors=full) ;;
        8bit)  CHAFA_ARGS+=(--colors=256) ;;
        bw)    CHAFA_ARGS+=(--colors=none) ;;
    esac
    [[ -n "$WIDTH" && -n "$HEIGHT" ]] && CHAFA_ARGS+=(--size="${WIDTH}x${HEIGHT}")
    [[ -n "$WIDTH" && -z "$HEIGHT" ]] && CHAFA_ARGS+=(--size="${WIDTH}x")
    [[ -z "$WIDTH" && -n "$HEIGHT" ]] && CHAFA_ARGS+=(--size="x${HEIGHT}")
fi

# --- step 4: render ---
if [[ "$RENDERER" == "ascii" ]]; then
    if [[ -n "$OUTPUT" && "$PREVIEW" == "true" ]]; then
        jp2a "${JP2A_ARGS[@]}" "$TMP" | tee "$OUTPUT" || die "jp2a failed"
    elif [[ -n "$OUTPUT" ]]; then
        jp2a "${JP2A_ARGS[@]}" --output="$OUTPUT" "$TMP" || die "jp2a failed"
    else
        jp2a "${JP2A_ARGS[@]}" "$TMP" || die "jp2a failed"
    fi
else
    if [[ -n "$OUTPUT" && "$PREVIEW" == "true" ]]; then
        chafa "${CHAFA_ARGS[@]}" "$TMP" | tee "$OUTPUT" || die "chafa failed"
    elif [[ -n "$OUTPUT" ]]; then
        chafa "${CHAFA_ARGS[@]}" "$TMP" > "$OUTPUT" || die "chafa failed"
    else
        chafa "${CHAFA_ARGS[@]}" "$TMP" || die "chafa failed"
    fi
fi
